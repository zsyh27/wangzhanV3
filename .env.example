# =============================================================================
# 湖北科信达机电设备有限公司 - 项目配置文件
# =============================================================================
# 此文件包含项目所有配置，可直接提交到Git
# 修改配置后需要重新构建项目：npm run build
# =============================================================================

# =============================================================================
# 一、网站基础配置（必填）
# =============================================================================
# 说明：网站域名和名称，用于生成sitemap、SEO元数据等
# 获取位置：您的网站域名
NEXT_PUBLIC_SITE_URL=http://www.hubeikexinda.online
NEXT_PUBLIC_SITE_NAME=湖北科信达机电设备有限公司

# =============================================================================
# 二、百度统计配置（必填）
# =============================================================================
# 作用：网站流量统计分析
# 获取位置：
#   1. 访问 https://tongji.baidu.com/
#   2. 登录百度账号
#   3. 进入「管理」→「网站列表」→「新增网站」
#   4. 填写网站信息后，获取统计ID
#   5. 统计代码格式：hm.src = "https://hm.baidu.com/hm.js?9d9dae709a219a3eaf305f235ec7be5f"
#   6. 提取 ? 后面的部分作为 BAIDU_TONGJI_ID
BAIDU_TONGJI_ID=9d9dae709a219a3eaf305f235ec7be5f

# =============================================================================
# 三、百度搜索资源平台配置（必填）
# =============================================================================
# 作用：网站收录、SEO优化、主动推送
# 获取位置：
#   1. 访问 https://ziyuan.baidu.com/
#   2. 登录百度账号
#   3. 点击「添加网站」，输入网站地址
#   4. 验证网站所有权（推荐HTML标签验证）
#   5. 验证通过后，进入「链接提交」→「普通收录」→「API提交」
#   6. 复制接口调用地址，提取 site 和 token 参数
# 示例：http://data.zz.baidu.com/urls?site=www.example.com&token=xxxxx
#       BAIDU_PUSH_SITE=www.example.com
#       BAIDU_PUSH_TOKEN=xxxxx
BAIDU_PUSH_SITE=http://www.hubeikexinda.online
BAIDU_PUSH_TOKEN=EddKeIeUkk2921ZE

# =============================================================================
# 四、百度站点验证配置（可选）
# =============================================================================
# 作用：验证网站所有权，使用百度搜索资源平台的SEO工具
# 获取位置：
#   1. 访问 https://ziyuan.baidu.com/
#   2. 进入「用户中心」→「站点管理」
#   3. 选择验证方式（HTML标签验证）
#   4. 复制验证代码，例如：codeva-ABCDEFGHIJ
#   5. 将 codeva-ABCDEFGHIJ 填入下方
# 注意：如果不验证，网站也能正常访问和收录，但无法使用百度SEO工具
BAIDU_VERIFICATION_CODE=codeva-bMl4jP7kZ0

# =============================================================================
# 五、月之暗面（Moonshot AI）API配置（可选）
# =============================================================================
# 作用：AI自动生成SEO文章
# 获取位置：
#   1. 访问 https://platform.moonshot.cn/
#   2. 注册/登录账号
#   3. 进入「API Key管理」
#   4. 点击「创建API Key」
#   5. 复制生成的API Key（格式：sk-xxxxxxxx）
# 注意：如果不配置，AI内容生成脚本将使用模拟数据
MOONSHOT_API_KEY=sk-VdYLhau6wgfjl8BExO9p1x3V2D8hNHzEh8fRjsaEA8EOiW5b

# =============================================================================
# 六、AI内容生成配置（可选，使用默认值即可）
# =============================================================================
# 说明：控制AI生成文章的字数范围和关键词密度
# 默认值已适合SEO优化，一般无需修改

# 文章字数范围
AI_CONTENT_MIN_WORDS=1500
AI_CONTENT_MAX_WORDS=3000

# 关键词密度（2%-3%为SEO最佳范围）
AI_KEYWORD_DENSITY_MIN=0.02
AI_KEYWORD_DENSITY_MAX=0.03

# 最大重试次数
AI_MAX_RETRIES=3

# =============================================================================
# 七、微信服务号配置（可选）
# =============================================================================
# 作用：将网站新闻同步到微信服务号
# 获取位置：
#   1. 访问 https://developers.weixin.qq.com/console/product/mp-service/wx4667be81cc085b67?tab1=basicInfo&tab2=wxAccount
#   2. 登录微信服务号后台
#   3. 进入「开发」→「基本配置」
#   4. 获取AppID和AppSecret
# 注意：需要认证的服务号才能使用发布能力
WECHAT_APPID=wx4667be81cc085b67
WECHAT_APPSECRET=ef930e426fc0dec20545cebe1be3d1c8

# =============================================================================
# 配置说明结束
# =============================================================================
# 修改配置后，请执行以下命令使配置生效：
#   npm run build
# =============================================================================
